# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL="YOUR_SUPABASE_URL"

# SUPABASE_SERVICE_ROLE_KEY: The service role key for backend access.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# GMAIL_USER: Your Gmail address for sending notifications (e.g., your.email@gmail.com)
GMAIL_USER="YOUR_GMAIL_ADDRESS"

# GMAIL_APP_PASSWORD: An App Password generated from your Google Account security settings
GMAIL_APP_PASSWORD="YOUR_GMAIL_APP_PASSWORD"

# GOOGLE_CLIENT_ID: Your Google Cloud OAuth Client ID for Google Drive API
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# GOOGLE_CLIENT_SECRET: Your Google Cloud OAuth Client Secret
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
